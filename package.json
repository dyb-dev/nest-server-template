{
    "name": "nest-server-template",
    "version": "1.4.0",
    "description": "基于`nest全家桶`搭建的服务端模板",
    "author": "dyb-dev",
    "license": "MIT",
    "type": "module",
    "private": true,
    "main": "./src/main.ts",
    "scripts": {
        "prepare": "husky",
        "dev": "vite",
        "build": "npm run ts-check && npm run build-only",
        "build-only": "vite build",
        "start": "node ./dist/main.js",
        "ts-check": "tsc --build --force",
        "release": "project-cli release",
        "format": "prettier --write . && eslint --fix .",
        "prisma:dev": "prisma migrate dev && prisma generate",
        "prisma:deploy": "prisma migrate deploy && prisma generate",
        "prisma:studio": "prisma studio"
    },
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=8.15.5 <10.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/dyb-dev/nest-server-template"
    },
    "homepage": "https://github.com/dyb-dev/nest-server-template",
    "bugs": {
        "url": "https://github.com/dyb-dev/nest-server-template/issues",
        "directory": "https://github.com/dyb-dev/nest-server-template"
    },
    "devDependencies": {
        "@dyb-dev/eslint-config": "^1.1.1",
        "@dyb-dev/prettier-config": "^0.0.5",
        "@dyb-dev/project-cli": "^0.0.10",
        "@dyb-dev/ts-config": "^0.1.4",
        "@swc/core": "^1.15.18",
        "@types/bcrypt": "^6.0.0",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.0",
        "@types/multer": "^2.0.0",
        "@types/node": "^22.10.7",
        "@types/pg": "^8.16.0",
        "eslint": "^8.57.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "prettier": "^3.4.2",
        "prettier-eslint": "^16.4.2",
        "prisma": "^7.1.0",
        "typescript": "^5.7.3",
        "vite": "^7.2.7",
        "vite-plugin-node": "^7.0.0"
    },
    "dependencies": {
        "@casl/ability": "^6.7.3",
        "@keyv/redis": "^5.1.4",
        "@nestjs-cls/transactional": "^3.2.0",
        "@nestjs-cls/transactional-adapter-prisma": "^1.3.4",
        "@nestjs/axios": "^4.0.1",
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/cache-manager": "^3.0.1",
        "@nestjs/common": "^11.0.1",
        "@nestjs/core": "^11.0.1",
        "@nestjs/event-emitter": "^3.0.1",
        "@nestjs/jwt": "^11.0.1",
        "@nestjs/mapped-types": "^2.1.0",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/throttler": "^6.4.0",
        "@prisma/adapter-pg": "^7.1.0",
        "@prisma/client": "^7.1.0",
        "axios": "^1.13.2",
        "bcrypt": "^6.0.0",
        "bullmq": "^5.64.1",
        "cache-manager": "^7.2.5",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.2",
        "cookie-parser": "^1.4.7",
        "cron": "^4.4.0",
        "csrf-csrf": "^4.0.3",
        "dayjs": "^1.11.19",
        "es-toolkit": "^1.42.0",
        "helmet": "^8.1.0",
        "ipaddr.js": "^2.3.0",
        "multer": "^2.0.2",
        "nestjs-cls": "^6.2.0",
        "nestjs-pino": "^4.4.1",
        "pg": "^8.16.3",
        "pino": "^10.1.0",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.2",
        "query-string": "^9.3.1",
        "reflect-metadata": "^0.2.2",
        "request-ip": "^3.3.0",
        "rotating-file-stream": "^3.2.7",
        "rxjs": "^7.8.1",
        "svg-captcha": "^1.4.0",
        "ua-parser-js": "^2.0.9"
    },
    "lint-staged": {
        "*": [
            "prettier --write",
            "eslint --fix"
        ]
    }
}