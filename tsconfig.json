/*
 * @FileDesc: ts 配置
 */

{
    "extends": "@dyb-dev/ts-config/node",
    "include": ["src/**/*.ts", "src/**/*.d.ts", "prisma.config.ts", "vite.config.ts"],
    "exclude": ["node_modules", "**/node_modules", ".history"],
    "compilerOptions": {
        // 指定要包含的类型定义文件
        "types": ["vite/client", "@dyb-dev/ts-config/types", "@types/multer"],
        // 指定用于存储 TypeScript 编译器在增量编译模式下生成的编译信息的文件路径，以便下次编译时可以使用
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
        // 设置基础路径，解决模块导入路径问题
        "baseUrl": "./",
        // 配置路径映射，简化模块导入路径
        "paths": {
            "@/*": ["./src/*"]
        },
        // 允许使用实验性的装饰器语法
        "experimentalDecorators": true,
        // 允许生成装饰器元数据
        "emitDecoratorMetadata": true
    }
}
